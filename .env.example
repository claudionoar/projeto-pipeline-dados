# Copie este arquivo para ".env" e preencha com seus valores reais.
# NUNCA comite o .env no Git (adicione-o ao .gitignore).

# ---- Snowflake ----
# O ACCOUNT costuma ter o formato <org>-<conta>, ex: ab12345-xy67890
SNOWFLAKE_ACCOUNT=sua_conta_aqui
SNOWFLAKE_USER=seu_usuario
SNOWFLAKE_PASSWORD=sua_senha
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ANALYTICS

# ---- AWS / S3 ----
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
AWS_SESSION_TOKEN=seu_token_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=meu-bucket-modelagem-ifg